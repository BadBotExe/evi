{
  "type": "bonfire_sacrifice",
  "tiers_formula": {
    "type": "linear",
    "label_prefix": "Tier",
    "max_tier": 42
  },
  "enhancement_costs": {
    "material": {
      "item": "{{item}}",
      "amount": { "type": "exponential", "base": 500, "growth": 1.3, "level_offset": 1, "round": "ceil" }
    },
    "crystallized": {
      "item": "{{item}}",
      "amount": { "type": "exponential", "base": 50, "growth": 1.11, "level_offset": 1, "round": "ceil" }
    },
    "ash": {
      "item": "ash",
      "amount": { "type": "linear", "base": 250, "step": 50, "level_offset": 1 }
    }
  },
  "enhancement_segments": {
    "default": { "to_level": 42, "costs": [{ "$ref": "#/enhancement_costs/material" }, { "$ref": "#/enhancement_costs/ash" }] },
    "speed": { "to_level": 20, "costs": [{ "$ref": "#/enhancement_costs/material" }, { "$ref": "#/enhancement_costs/ash" }] },
    "crystallized": { "to_level": 42, "costs": [{ "$ref": "#/enhancement_costs/crystallized" }, { "$ref": "#/enhancement_costs/ash" }] }
  },
  "enhancements": {
    "default": {
      "max_level": 42,
      "display": { "totals": { "group_by": 10 } },
      "segments": [{ "$ref": "#/enhancement_segments/default" }]
    },
    "speed": {
      "max_level": 20,
      "display": { "totals": { "group_by": 10 } },
      "segments": [{ "$ref": "#/enhancement_segments/speed" }]
    },
    "crystallized": {
      "max_level": 42,
      "display": { "totals": { "group_by": 10 } },
      "segments": [{ "$ref": "#/enhancement_segments/crystallized" }]
    }
  },
  "bonuses": [
