{
  "type": "hunter_upgrades",
  "tiers_formula": {
    "type": "linear",
    "label_prefix": "Tier",
    "max_tier": 57
  },
  "enhancement_costs": {
    "common": {
      "item": "{{item}}",
      "amount": { "type": "exponential", "base": 1, "growth": 1.7, "level_offset": 0 }
    }
  },
  "enhancement_segments": {
    "default": {
      "to_level": 57,
      "costs": [
        { "$ref": "#/enhancement_costs/common" }
      ]
    },
    "attack_speed": {
      "to_level": 30,
      "costs": [
        { "$ref": "#/enhancement_costs/common" }
      ]
    }
  },
  "cost_modifiers": {
    "hunter_cost_breakdown": {
      "id": "hunter_cost_breakdown",
      "key": "hcb",
      "label": "Hunter Cost Breakdown",
      "formula_variable": "Breakdown",
      "operation": "multiply_percent_remaining",
      "default": 0,
      "min": 0,
      "max": 99,
      "step": 1
    },
    "hunter_cost_reduction": {
      "id": "hunter_cost_reduction",
      "key": "hcr",
      "label": "Hunter Cost Reduction",
      "formula_variable": "Reduction",
      "operation": "divide_percent_increase",
      "default": 0,
      "min": 0,
      "step": 100
    }
  },
  "enhancements": {
    "default": {
      "max_level": 57,
      "display": {
        "totals": {
          "group_by": 10
        }
      },
      "cost_modifiers": [
        { "$ref": "#/cost_modifiers/hunter_cost_breakdown" },
        { "$ref": "#/cost_modifiers/hunter_cost_reduction" }
      ],
      "segments": [
        { "$ref": "#/enhancement_segments/default" }
      ]
    },
    "attack_speed": {
